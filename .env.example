# plm-ai-apps — local development environment.
#
# NEVER commit real credentials. Copy this file to .env and fill in values.
#   cp .env.example .env
#
# Non-secret defaults live in config/base.yaml.
# Override YAML fields with APP__SECTION__KEY=value (double underscore separator).
#   config/base.yaml:  toss.app_name: plm-ai-apps
#   env override:      APP__TOSS__APP_NAME=my-local-app
#
# On TAP, secrets arrive at /tap/secret/* via runtime-connector.
# ─────────────────────────────────────────────────────────────────────────────

# ── App runtime ───────────────────────────────────────────────────────────────
APP__APP__ENV=development
APP__APP__LOG_LEVEL=DEBUG

# ── LLM provider: thinktank | openai | none ───────────────────────────────────
# Set to "none" to disable LLM calls locally (service starts without credentials).
APP__LLM__PROVIDER=thinktank
APP__LLM__MODEL=gemini-1.5-pro

# ── ThinkTank / Model Garden ──────────────────────────────────────────────────
# Option A — OAuth (Target internal environments).
#   Requires tgt-certs and pyOauthTarget to be installed.
#   Install: uv add tgt-certs pyOauthTarget --index tgt-python
THINKTANK_OAUTH_CLIENT_ID=
THINKTANK_OAUTH_CLIENT_SECRET=
THINKTANK_OAUTH_NUID_USERNAME=
THINKTANK_OAUTH_NUID_PASSWORD=

# Option B — Static API key fallback (external / local dev).
#   If OAUTH credentials are blank, this is used automatically.
THINKTANK_API_KEY=

# Optional: gateway subscription key (sent as x-api-key header).
THINKTANK_GATEWAY_API_KEY=

# ── ThinkTank endpoint overrides (only needed if base_url differs from base.yaml)
# APP__THINKTANK__BASE_URL=https://api-internal.target.com
# APP__THINKTANK__CHAT_ENDPOINT=/gen_ai_model_requests/v1/chat/completions
# APP__THINKTANK__APP_NAME=plm-ai-apps
# APP__THINKTANK__TENANT_ID=
# APP__THINKTANK__IS_PROD=false

# ── Server ────────────────────────────────────────────────────────────────────
# plm-think-tank-ai  →  :8000   (set in apps/plm-think-tank-ai/.env or here)
# plm-tcin-mapper    →  :8001   (set in apps/plm-tcin-mapper/.env or here)
APP__SPARK__HOST=0.0.0.0
APP__SPARK__PORT=8000

# ── MongoDB — required by plm-tcin-mapper only, ignored by plm-think-tank-ai ─
# Override in apps/plm-tcin-mapper/.env (preferred) or set here.
# APP__MONGO__URL=mongodb://root:password@localhost:27017
# APP__MONGO__DATABASE=tcin_mapper
