# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values.
# .env is git-ignored. Never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM provider secrets ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
THINKTANK_API_KEY=...

# ── ThinkTank / TOSS connection (override base.yaml defaults if needed) ───────
# APP__TOSS__BASE_URL=https://thinktank.prod.target.com
# APP__TOSS__APP_NAME=my-test-ai-app    # sent as x-tgt-application header
# APP__TOSS__IS_PROD=true               # true = prod OAuth endpoint

# ── ThinkTank OAuth credentials ───────────────────────────────────────────────
THINKTANK_OAUTH_CLIENT_ID=
THINKTANK_OAUTH_CLIENT_SECRET=
THINKTANK_OAUTH_NUID_USERNAME=
THINKTANK_OAUTH_NUID_PASSWORD=

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH__URL=http://localhost:9200
ELASTICSEARCH__USERNAME=elastic
ELASTICSEARCH__PASSWORD=changeme

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Embed credentials directly in the connection URL.
# Local dev (no auth):   mongodb://localhost:27017
# Authenticated:         mongodb://user:pass@host:27017/mydb
# Atlas / SRV:           mongodb+srv://user:pass@cluster.mongodb.net/mydb
MONGO__URL=mongodb://localhost:27017

# ── Config path overrides (optional) ─────────────────────────────────────────
# APP_CONFIG_PATH=./config/base.yaml   # point at a specific file or directory
