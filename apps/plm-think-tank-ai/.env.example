# apps/plm-think-tank-ai — app-specific overrides.
#
# This file is layered ON TOP of the root .env (root wins shared secrets;
# values here win for anything declared in both files).
#
# Copy to .env and fill in only the vars that differ from root defaults.
#   cp apps/plm-think-tank-ai/.env.example apps/plm-think-tank-ai/.env
#
# Leave a line blank to inherit the value from the root .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Mongo (app-specific) ──────────────────────────────────────────────────────
# APP__MONGO__URL=mongodb://localhost:27017
# APP__MONGO__DATABASE=plm-think-tank-local

# ── Elasticsearch (app-specific) ─────────────────────────────────────────────
# APP__ELASTICSEARCH__URL=http://localhost:9200
# APP__ELASTICSEARCH__USERNAME=
# APP__ELASTICSEARCH__PASSWORD=

# ── TOSS / object storage (app-specific) ─────────────────────────────────────
# TOSS_BUCKET=
# TOSS_ACCESS_KEY=
# TOSS_SECRET_KEY=

# ── ThinkTank overrides (only if this app targets a different tenant/endpoint)
# APP__THINKTANK__TENANT_ID=
# APP__THINKTANK__BASE_URL=
