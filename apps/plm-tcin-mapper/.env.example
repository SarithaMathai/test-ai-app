# apps/plm-tcin-mapper — app-specific overrides.
#
# This file is layered ON TOP of the root .env (root wins shared secrets like
# ThinkTank OAuth; values here win for anything declared in both files).
#
# Copy to .env and fill in the values that differ from the root defaults:
#   cp apps/plm-tcin-mapper/.env.example apps/plm-tcin-mapper/.env
#
# Leave a line blank/commented to inherit from the root .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── App identity ──────────────────────────────────────────────────────────────
APP__APP__NAME=plm-tcin-mapper

# ── MongoDB — REQUIRED by this app (plm-tcin-mapper) ──────────────────────────
# Embed credentials directly in the URL. The app uses both async (Motor) and
# sync (PyMongo) clients from ai-mongo against this single instance.
APP__MONGO__URL=mongodb://localhost:27017
APP__MONGO__DATABASE=tcin_mapper

# ── LLM (ThinkTank for low-confidence disambiguation) ─────────────────────────
# Inherits ThinkTank OAuth/API credentials from the root .env. Set the provider
# to "none" to run the matching pipeline deterministically with no LLM calls.
# APP__LLM__PROVIDER=thinktank
# APP__LLM__MODEL=gemini-1.5-pro

# ── Ingestion (override the data directory if your CSVs live elsewhere) ───────
# APP__INGESTION__DATA_DIR=apps/plm-tcin-mapper/data/normalized
# APP__INGESTION__BATCH_SIZE=500

# ── Server ────────────────────────────────────────────────────────────────────
# The Makefile binds the API to :8001 explicitly. This is the port the
# `tcin-mapper-start` console script / gunicorn entrypoint uses.
APP__SPARK__HOST=0.0.0.0
APP__SPARK__PORT=8001
